rules_version = '2';

// License store security rules.
//
// licenses/{machineId} documents are written ONLY by Cloud Functions via the
// Admin SDK, which bypasses these rules entirely (it authenticates with Google
// Application Default Credentials / IAM, not rules). Clients — the Electron app
// using the public Firebase web config — may only READ a single document by its
// machineId, and may NOT enumerate the collection or write anything.
service cloud.firestore {
  match /databases/{database}/documents {

    match /licenses/{machineId} {
      // Anyone who already knows the machineId may read that one document.
      // The machineId is a salted SHA-256 hash held locally by the app, so this
      // is effectively a capability key — not guessable / not enumerable.
      allow get: if true;

      // Block 'list' so the licenses collection cannot be enumerated/queried.
      allow list: if false;

      // No client (web/Electron) may ever write. Only Admin SDK / Functions.
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
