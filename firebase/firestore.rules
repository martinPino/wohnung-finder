rules_version = '2';

// License store security rules.
//
// licenses/{machineId} documents are written ONLY by Cloud Functions via the
// Admin SDK, which bypasses these rules entirely (it authenticates with Google
// Application Default Credentials / IAM, not rules). Clients — the Electron app
// using the public Firebase web config — may only READ a single document by its
// machineId, and may NOT enumerate the collection or write anything.
service cloud.firestore {
  match /databases/{database}/documents {

    match /licenses/{machineId} {
      // Anyone who already knows the machineId may read that one document.
      // The machineId is a salted SHA-256 hash held locally by the app, so this
      // is effectively a capability key — not guessable / not enumerable.
      allow get: if true;

      // Block 'list' so the licenses collection cannot be enumerated/queried.
      allow list: if false;

      // No client (web/Electron) may ever write. Only Admin SDK / Functions.
      allow write: if false;
    }

    // Public product reviews shown on the landing page.
    // Anyone may read the list and create a review; the document is validated
    // (bounded lengths, rating 1–5, server timestamp). Reviews are immutable
    // from clients — no edits/deletes (moderation via Admin SDK / console).
    match /reviews/{id} {
      allow read: if true;

      allow create: if
        request.resource.data.keys().hasOnly(['name', 'text', 'rating', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 40
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 500
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
