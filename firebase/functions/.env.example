# Non-secret string params for Cloud Functions (firebase-functions/params defineString).
# Copy to functions/.env and fill in. The two REAL secrets (PADDLE_API_KEY,
# PADDLE_WEBHOOK_SECRET) are NOT here — set them in Secret Manager via:
#   firebase functions:secrets:set PADDLE_API_KEY
#   firebase functions:secrets:set PADDLE_WEBHOOK_SECRET

# "sandbox" while testing, "production" for live.
PADDLE_ENV=sandbox

# Paddle Billing price ids (Catalog > Products > Prices).
PRICE_MONTHLY=pri_<<monthly_price_id>>
PRICE_LIFETIME=pri_<<lifetime_price_id>>
